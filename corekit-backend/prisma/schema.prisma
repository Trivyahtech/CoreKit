generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String       @id @default(cuid())
  name           String
  slug           String       @unique
  status         TenantStatus @default(ACTIVE)
  currencyCode   String       @default("INR")
  defaultCountry String       @default("IN")
  timezone       String       @default("Asia/Kolkata")
  theme          Json?
  settings       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  domains        TenantDomain[]
  users          User[]
  vendorProfiles VendorProfile[]
  categories     Category[]
  products       Product[]
  variants       ProductVariant[]
  addresses      Address[]
  carts          Cart[]
  coupons        Coupon[]
  shippingZones  ShippingZone[]
  orders         Order[]
  payments       Payment[]
  reviews        Review[]
}

model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String
  host      String   @unique
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model User {
  id                 String     @id @default(cuid())
  tenantId           String
  email              String
  passwordHash       String?    // Optional for social logins
  googleId           String?
  hashedRefreshToken String?
  firstName          String
  lastName           String?
  phone              String?
  role               UserRole   @default(CUSTOMER)
  status             UserStatus @default(ACTIVE)
  lastLoginAt        DateTime?
  metadata     Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile?
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  reviews       Review[]

  @@unique([tenantId, email])
  @@unique([tenantId, googleId])
  @@index([tenantId, role, status])
}

model VendorProfile {
  id               String       @id @default(cuid())
  tenantId         String
  userId           String       @unique
  status           VendorStatus @default(PENDING)
  displayName      String
  businessName     String?
  gstin            String?
  verificationMeta Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  products   Product[]
  orderItems OrderItem[]

  @@index([tenantId, status])
}

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  parentId    String?
  name        String
  slug        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  meta        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[]        @relation("CategoryTree")
  products ProductCategory[]

  @@unique([tenantId, slug])
  @@index([tenantId, parentId, isActive])
}

model Product {
  id               String        @id @default(cuid())
  tenantId         String
  vendorId         String?
  name             String
  slug             String
  shortDescription String?
  description      String?
  brand            String?
  status           ProductStatus @default(DRAFT)
  isPublished      Boolean       @default(false)
  taxCode          String?
  taxRate          Decimal?      @db.Decimal(5, 2)
  meta             Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor     VendorProfile?    @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  images     ProductImage[]
  variants   ProductVariant[]
  categories ProductCategory[]
  cartItems  CartItem[]
  orderItems OrderItem[]
  reviews    Review[]

  @@unique([tenantId, slug])
  @@index([tenantId, status, isPublished])
  @@index([tenantId, vendorId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id             String        @id @default(cuid())
  tenantId       String
  productId      String
  sku            String
  title          String?
  attributes     Json
  price          Decimal       @db.Decimal(12, 2)
  compareAtPrice Decimal?      @db.Decimal(12, 2)
  stockOnHand    Int           @default(0)
  reservedStock  Int           @default(0)
  weightGrams    Int?
  status         VariantStatus @default(ACTIVE)
  meta           Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([tenantId, sku])
  @@index([productId, status])
  @@index([tenantId, stockOnHand])
}

model ProductCategory {
  productId  String
  categoryId String
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

model Address {
  id        String      @id @default(cuid())
  tenantId  String
  userId    String
  type      AddressType @default(SHIPPING)
  fullName  String
  phone     String
  line1     String
  line2     String?
  landmark  String?
  city      String
  state     String
  country   String      @default("India")
  pincode   String
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isDefault])
  @@index([tenantId, pincode])
}

model Cart {
  id             String     @id @default(cuid())
  tenantId       String
  userId         String
  status         CartStatus @default(ACTIVE)
  subtotal       Decimal    @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal    @default(0) @db.Decimal(12, 2)
  shippingAmount Decimal    @default(0) @db.Decimal(12, 2)
  discountAmount Decimal    @default(0) @db.Decimal(12, 2)
  grandTotal     Decimal    @default(0) @db.Decimal(12, 2)
  expiresAt      DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  CartItem[]

  @@index([tenantId, userId, status])
}

model CartItem {
  id            String   @id @default(cuid())
  tenantId      String
  cartId        String
  productId     String
  variantId     String
  titleSnapshot String
  skuSnapshot   String
  unitPrice     Decimal  @db.Decimal(12, 2)
  quantity      Int
  totalPrice    Decimal  @db.Decimal(12, 2)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([cartId, variantId])
  @@index([tenantId, cartId])
}

model Coupon {
  id                String     @id @default(cuid())
  tenantId          String
  code              String
  type              CouponType
  value             Decimal    @db.Decimal(12, 2)
  minCartValue      Decimal?   @db.Decimal(12, 2)
  maxDiscountAmount Decimal?   @db.Decimal(12, 2)
  usageLimit        Int?
  usedCount         Int        @default(0)
  startsAt          DateTime?
  endsAt            DateTime?
  isActive          Boolean    @default(true)
  metadata          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive, startsAt, endsAt])
}

model ShippingZone {
  id        String           @id @default(cuid())
  tenantId  String
  name      String
  type      ShippingZoneType @default(PINCODE)
  pincodes  Json
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules  ShippingRule[]

  @@index([tenantId, isActive])
}

model ShippingRule {
  id             String         @id @default(cuid())
  zoneId         String
  name           String
  method         ShippingMethod
  minWeightGrams Int?
  maxWeightGrams Int?
  flatRate       Decimal?       @db.Decimal(12, 2)
  ratePerKg      Decimal?       @db.Decimal(12, 2)
  minOrderValue  Decimal?       @db.Decimal(12, 2)
  isCodAllowed   Boolean        @default(true)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  zone ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId, isActive, method])
}

model Order {
  id                String            @id @default(cuid())
  tenantId          String
  userId            String
  orderNumber       String
  status            OrderStatus       @default(CREATED)
  paymentStatus     PaymentStatus     @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  subtotal          Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal           @default(0) @db.Decimal(12, 2)
  shippingAmount    Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount    Decimal           @default(0) @db.Decimal(12, 2)
  grandTotal        Decimal           @default(0) @db.Decimal(12, 2)
  currencyCode      String            @default("INR")
  couponCode        String?
  billingAddress    Json
  shippingAddress   Json
  customerNote      String?
  internalNote      String?
  placedAt          DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  items      OrderItem[]
  statusLogs OrderStatusLog[]
  payments   Payment[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, userId, status])
  @@index([tenantId, paymentStatus, fulfillmentStatus])
}

model OrderItem {
  id          String          @id @default(cuid())
  tenantId    String
  orderId     String
  productId   String
  variantId   String?
  vendorId    String?
  productName String
  variantName String?
  sku         String
  unitPrice   Decimal         @db.Decimal(12, 2)
  quantity    Int
  subtotal    Decimal         @db.Decimal(12, 2)
  taxAmount   Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount Decimal         @db.Decimal(12, 2)
  status      OrderItemStatus @default(CREATED)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  vendor  VendorProfile?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([tenantId, orderId])
  @@index([tenantId, vendorId, status])
}

model OrderStatusLog {
  id              String       @id @default(cuid())
  orderId         String
  fromStatus      OrderStatus?
  toStatus        OrderStatus
  note            String?
  createdByUserId String?
  createdAt       DateTime     @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model Payment {
  id               String          @id @default(cuid())
  tenantId         String
  orderId          String
  provider         PaymentProvider
  method           PaymentMethod?
  status           PaymentStatus   @default(PENDING)
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  amount           Decimal         @db.Decimal(12, 2)
  currencyCode     String          @default("INR")
  rawPayload       Json?
  processedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId, orderId, status])
  @@index([provider, gatewayPaymentId])
}

model Review {
  id                 String       @id @default(cuid())
  tenantId           String
  productId          String
  userId             String
  rating             Int
  title              String?
  body               String?
  isVerifiedPurchase Boolean      @default(false)
  status             ReviewStatus @default(PENDING)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([tenantId, productId, status])
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum UserRole {
  ADMIN
  VENDOR
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
  DELETED
}

enum VendorStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum VariantStatus {
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
}

enum AddressType {
  BILLING
  SHIPPING
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum CouponType {
  FLAT
  PERCENTAGE
}

enum ShippingZoneType {
  PINCODE
  REGION
}

enum ShippingMethod {
  STANDARD
  EXPRESS
  SAME_DAY
  PICKUP
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum OrderItemStatus {
  CREATED
  CONFIRMED
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  PENDING
  PARTIAL
  FULFILLED
  RETURNED
}

enum PaymentProvider {
  RAZORPAY
  COD
  MANUAL
}

enum PaymentMethod {
  UPI
  CARD
  NETBANKING
  WALLET
  COD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
